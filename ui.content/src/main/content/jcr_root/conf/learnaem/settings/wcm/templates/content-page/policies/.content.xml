<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template Policy Mappings for Content Page
  Maps parsys containers to component policies that control which
  components authors can drag and drop onto the page.
-->
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="nt:unstructured"
          sling:resourceType="wcm/core/components/policies/mappings">
    <jcr:content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="wcm/core/components/policies/mappings">
        <root
            jcr:primaryType="nt:unstructured"
            cq:policy="/conf/learnaem/settings/wcm/policies/wcm/foundation/components/responsivegrid/default"
            sling:resourceType="wcm/foundation/components/responsivegrid"/>
    </jcr:content>
</jcr:root>
